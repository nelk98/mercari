PORT=2999
INTERVAL_MIN_MS=20000
INTERVAL_MAX_MS=30000
# 单源 Playwright 超时（goto/等待列表等），过短易出现 0 条
SCRAPE_TIMEOUT_MS=30000
SCRAPE_RETRIES=0
# 默认顺序抓取（源之间错开间隔）；需要并发时设 SCRAPE_CONCURRENT=1
# SCRAPE_CONCURRENT=1
# SCRAPE_CONCURRENCY=5
# 保留供后续统计/扩展；顺序模式下单源超时以 SCRAPE_TIMEOUT_MS 为准，不再按预算压短
SCRAPE_ROUND_BUDGET_MS=30000
# 相邻两源开始之间的间隔（毫秒），减轻瞬时压力
SCRAPE_STAGGER_GAP_MS=180
# 顺序 + 共享 Context 时：全部页签刷新完后再等多久再统一读列表（异步搜索结果落稳）
# SCRAPE_POST_REFRESH_WAIT_MS=2500
# 每个源单独新建浏览器上下文（无 Cookie、随机 UA/视口），略慢，可降低同一会话被关联的风险
SCRAPE_FRESH_CONTEXT=0
# Mercari /search 同订阅 URL 时优先点击顶栏搜索区按钮刷新列表；设为 0/false/off/no 则始终 reload
# SCRAPE_SOFT_REFRESH=0
# 为 1 时服务端启动后抓取默认使用有头浏览器；托盘「显示抓取浏览器」也会临时开启并触发一轮抓取
# SCRAPE_HEADED=1
# 可选代理出口，例如 http://127.0.0.1:7890（换公网 IP 需自备合规代理）
# SCRAPE_PROXY_SERVER=
# 使用本机已安装的 Chrome（Playwright channel），无头/有头行为更接近，部分站点无头被拦时可试
# PLAYWRIGHT_CHANNEL=chrome
