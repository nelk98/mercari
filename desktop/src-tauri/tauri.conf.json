{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mercari Widget",
  "version": "0.1.0",
  "identifier": "com.mercari.push",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "widget",
        "title": "Mercari Widget",
        "width": 280,
        "height": 84,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true,
        "url": "/?mode=widget"
      },
      {
        "label": "panel",
        "title": "Mercari Panel",
        "width": 1080,
        "height": 760,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "url": "/?mode=panel"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
