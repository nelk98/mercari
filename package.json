{
  "name": "mercari-push-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run dev:full",
    "run:app": "pnpm run dev:full",
    "dev:full": "concurrently -k -n server,desktop -c cyan,magenta \"pnpm --filter @mercari/server dev\" \"pnpm --filter @mercari/desktop tauri dev\"",
    "dev:server": "pnpm --filter @mercari/server dev",
    "desktop:dev": "pnpm --filter @mercari/desktop tauri dev",
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
